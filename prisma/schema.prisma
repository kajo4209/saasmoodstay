generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Chalet {
  id          Int       @id @default(autoincrement())
  name        String
  price       Int
  rooms       Int
  description String
  features    String    // مخزنة كـ string مفصولة بفواصل
  type        String    @default("family") // "family" | "youth"
  images      String[]  // مسارات الصور
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  bookings    Booking[]
}

model Booking {
  id         Int      @id @default(autoincrement())

  // علاقة الشاليه
  chaletId   Int
  chalet     Chalet   @relation(fields: [chaletId], references: [id])

  // بيانات العميل
  guestName  String
  phone      String

  // تواريخ الحجز
  checkIn    DateTime
  checkOut   DateTime

  // الحالة
  status     String   @default("pending") // pending | confirmed | cancelled

  // الدفع
  payment    String   @default("cash") // cash | online

  // السعر
  totalPrice Int

  createdAt  DateTime @default(now())
}